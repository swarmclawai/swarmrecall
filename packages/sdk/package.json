{
  "name": "@swarmrecall/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the SwarmRecall API — persistent memory, knowledge graphs, learnings, and skill tracking for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "swarmrecall",
    "ai",
    "agent",
    "memory",
    "knowledge-graph",
    "learnings",
    "skills",
    "llm",
    "claude",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/swarmrecall/swarmrecall.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://swarmrecall.ai",
  "bugs": {
    "url": "https://github.com/swarmrecall/swarmrecall/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@swarmrecall/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
